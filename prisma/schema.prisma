// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider     = "prisma-client"
  output       = "../src/core/infrastructure/persistence/prisma/generated/client"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum AuthProviderName {
  GOOGLE
  FACEBOOK
  GITHUB
}

enum Role {
  USER
  ADMIN
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  PENDING_VERIFICATION
  SUSPENDED
  DELETED
}

enum Gender {
  MALE
  FEMALE
}

/// Type of the one-time token stored in VerificationToken
enum VerificationTokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
  ACCOUNT_REACTIVATION
}

// ─────────────────────────────────────────────
// Models
// ─────────────────────────────────────────────

model Account {
  id              String    @id @default(uuid())
  email           String    @unique @db.VarChar(255)
  emailVerified   Boolean   @default(false)
  emailVerifiedAt DateTime?

  /// bcrypt-hashed password; null for OAuth-only accounts
  password              String?   @db.VarChar(255)
  lastPasswordChangedAt DateTime?

  role   Role          @default(USER)
  status AccountStatus @default(PENDING_VERIFICATION)

  /// Incremented on each failed login attempt; reset on successful login
  loginAttempts Int       @default(0)
  /// Lockout window expiry — account is locked while now() < lockedUntil
  lockedUntil   DateTime?
  lastLoginAt   DateTime?

  // Two-factor authentication (TOTP)
  twoFactorEnabled     Boolean  @default(false)
  /// TOTP secret — must be encrypted at the application layer before storing
  twoFactorSecret      String?  @db.VarChar(255)
  /// Hashed single-use backup codes (bcrypt or argon2)
  twoFactorBackupCodes String[] @default([])

  // Audit
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  providers      AuthProvider[]
  refreshTokens  RefreshToken[]
  loginHistories LoginHistory[]
  user           User?

  @@index([email])
  @@map("accounts")
}

model AuthProvider {
  id         String           @id @default(uuid())
  accountId  String
  provider   AuthProviderName
  providerId String           @db.VarChar(255)

  /// OAuth access token — encrypt at the application layer before storing
  accessToken    String?   @db.Text
  /// OAuth refresh token — encrypt at the application layer before storing
  refreshToken   String?   @db.Text
  tokenExpiresAt DateTime?
  /// Space-separated OAuth scopes granted by the user
  scope          String?   @db.VarChar(500)

  // Audit
  linkedAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@index([accountId])
  @@map("auth_providers")
}

/// Stores hashed refresh tokens with per-session device metadata.
/// Replaces the flat refreshTokens String[] on Account for proper expiry and revocation.
model RefreshToken {
  id        String @id @default(uuid())
  accountId String

  /// SHA-256 hash of the issued JWT — never store the raw token
  tokenHash String @unique @db.VarChar(255)

  // Session / device metadata
  ipAddress String? @db.VarChar(45) // supports IPv6 (max 45 chars)
  userAgent String? @db.VarChar(512)
  /// Optional stable device identifier (e.g. fingerprint hash)
  deviceId  String? @db.VarChar(255)

  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@map("refresh_tokens")
}

/// Generic one-time token for email verification, password reset, and account reactivation.
/// Always store the hash; send the raw token to the user via email.
// Remove this model, because we will use Redis to store OTPs with TTL instead of the database. This is just for demonstration purposes.
/**
 * model VerificationToken {
 * id        String                @id @default(uuid())
 * accountId String
 * type      VerificationTokenType
 * /// SHA-256 hash of the raw token sent to the user
 * tokenHash String @unique @db.VarChar(255)
 * expiresAt DateTime
 * usedAt    DateTime?
 * createdAt DateTime  @default(now())
 * account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
 * @@index([accountId])
 * @@index([accountId, type])
 * @@map("verification_tokens")
 * }
 */

/// Immutable audit log of every login attempt.
/// Powers new-login notifications and suspicious-activity alerts.
model LoginHistory {
  id        String @id @default(uuid())
  accountId String

  ipAddress String? @db.VarChar(45)
  userAgent String? @db.VarChar(512)
  /// Human-readable location derived from IP, e.g. "Jakarta, ID"
  location  String? @db.VarChar(255)

  success    Boolean
  /// Reason for failure when success = false, e.g. "INVALID_PASSWORD", "ACCOUNT_LOCKED"
  failReason String? @db.VarChar(255)

  createdAt DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([accountId, createdAt(sort: Desc)])
  @@map("login_histories")
}

model User {
  id          String    @id @default(uuid())
  accountId   String    @unique
  name        String    @db.VarChar(255)
  gender      Gender?
  dateOfBirth DateTime?
  phoneNumber String?   @db.VarChar(50)
  /// Profile picture URL — populated from OAuth provider or user upload
  avatarUrl   String?   @db.VarChar(1000)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  account   Account   @relation(fields: [accountId], references: [id])
  addresses Address[]

  @@map("users")
}

model Address {
  id     String @id @default(uuid())
  userId String

  label      String @db.VarChar(255)
  recipient  String @db.VarChar(255)
  phone      String @db.VarChar(50)
  street     String @db.VarChar(500)
  city       String @db.VarChar(255)
  province   String @db.VarChar(255)
  postalCode String @db.VarChar(20)
  country    String @default("Indonesia") @db.VarChar(100)

  latitude  Decimal? @db.Decimal(10, 7)
  longitude Decimal? @db.Decimal(10, 7)

  isDefault Boolean @default(false)

  // Audit
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("addresses")
}
